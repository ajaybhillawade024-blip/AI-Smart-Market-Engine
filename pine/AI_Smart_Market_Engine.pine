//@version=6
// ═══════════════════════════════════════════════════════════════════════════════
// AI Smart Market Engine PRO
// ═══════════════════════════════════════════════════════════════════════════════
// Version  : 1.1 — Professional Edition
// Market   : NIFTY 50 / BANKNIFTY Index (15 Minute)
// Purpose  : Non-repainting BUY CE / BUY PE signal engine for index options
// Design   : Modular architecture — engines added incrementally per release
// ═══════════════════════════════════════════════════════════════════════════════
//
// NON-REPAINTING GUARANTEE
// ─────────────────────────
// • All signals evaluated on bar close via barstate.isconfirmed
// • No request.security() with lookahead
// • No future-referencing offsets (negative bar indices for signals)
// • Swing / structure pivots confirmed only after right-bar confirmation
// • VWAP, EMA, ADX computed from historical data only
//
// RELEASE ROADMAP
// ───────────────
// v0.1  Core Framework
// v0.2  Trend + VWAP Engines
// v0.3  Market Structure Engine
// v0.4  Liquidity Engine
// v0.5  AI Confidence Engine
// v1.0  Complete Production Strategy
// v1.1  Professional Edition  ← current
// ═══════════════════════════════════════════════════════════════════════════════

strategy(
     title                  = "AI Smart Market Engine v1.1 Professional",
     shorttitle             = "AI SME PRO v1.1",
     overlay                = true,
     initial_capital        = 100000,
     default_qty_type       = strategy.fixed,
     default_qty_value      = 1,
     commission_type        = strategy.commission.percent,
     commission_value       = 0.03,
     pyramiding             = 0,
     calc_on_every_tick     = false,
     process_orders_on_close = true,
     max_bars_back          = 5000)

